<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>Русская клавиатура</title>

  <style>
    * {
      box-sizing: border-box;
    }

    html,
    body {
      margin: 0;
      padding: 0;
      width: 100%;
      height: 100%;
      overflow: hidden;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #ffffff;
      color: #111827;
    }

    .app {
      width: 100vw;
      height: 100dvh;
      padding: 10px;
      display: flex;
      flex-direction: column;
      gap: 8px;
      overflow: hidden;
    }

    .textBox {
      width: 100%;
      height: 96px;
      min-height: 96px;
      max-height: 96px;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
      padding: 12px 14px;
      border-radius: 16px;
      border: 1px solid #dbe2ea;
      background: #ffffff;
      box-shadow: inset 0 1px 2px rgba(0,0,0,0.04), 0 2px 10px rgba(0,0,0,0.06);
      font-size: 32px;
      line-height: 1.35;
      word-break: break-word;
      white-space: pre-wrap;
    }

    .topButtons {
      width: 100%;
      display: grid;
      grid-template-columns: 1fr 1fr 2fr;
      gap: 8px;
      flex: 0 0 auto;
    }

    button {
      border: none;
      cursor: pointer;
      user-select: none;
      -webkit-tap-highlight-color: transparent;
      touch-action: manipulation;
      font-family: inherit;
    }

    .actionButton {
      height: 50px;
      border-radius: 12px;
      background: linear-gradient(#ffffff, #f2f4f7);
      border: 1px solid #d7dde5;
      box-shadow: 0 2px 6px rgba(0,0,0,0.08);
      color: #111827;
      font-size: 24px;
      font-weight: 700;
    }

    .keyboard {
      flex: 1 1 auto;
      min-height: 0;
      width: 100%;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      gap: 8px;
    }

    .row {
      width: 100%;
      display: grid;
      gap: 8px;
    }

    .row1 {
      grid-template-columns: repeat(12, 1fr);
    }

    .row2 {
      grid-template-columns: repeat(11, 1fr);
    }

    .row3 {
      grid-template-columns: repeat(10, 1fr);
    }

    .key {
      height: 100%;
      min-height: 52px;
      border-radius: 12px;
      font-size: clamp(26px, 4.5vw, 46px);
      font-weight: 800;
      color: #111827;
      background: linear-gradient(#eaf4ff, #d7eaff);
      border: 1px solid #c5ddf8;
      box-shadow: 0 2px 6px rgba(0,0,0,0.08);
    }

    .key.disabled {
      background: linear-gradient(#f5f5f5, #e8e8e8);
      border-color: #d7d7d7;
      color: #222;
      opacity: 0.88;
    }

    @media (orientation: portrait) {
      .app {
        padding: 8px;
        gap: 7px;
      }

      .textBox {
        height: 110px;
        min-height: 110px;
        max-height: 110px;
        font-size: 28px;
      }

      .actionButton {
        height: 46px;
        font-size: 20px;
      }

      .row {
        gap: 4px;
      }

      .key {
        min-height: 44px;
        border-radius: 9px;
        font-size: clamp(18px, 6vw, 28px);
      }
    }
  </style>
</head>

<body>
  <div class="app">
    <div id="textBox" class="textBox">—</div>

    <div class="topButtons">
      <button class="actionButton" onclick="removeLastLetter()">⌫</button>
      <button class="actionButton" onclick="clearInput()">🗑</button>
      <button class="actionButton" onclick="addSpace()">ПРОБЕЛ</button>
    </div>

    <div id="keyboard" class="keyboard"></div>
  </div>

  <script>
    const DICTIONARY_URL =
      "https://raw.githubusercontent.com/antonLingo/Words/0b8400df77208e47ad6a537be53892fed244a769/russian_words_utf8.txt";

    const FALLBACK_WORDS = `
мне нужно записаться к врачу боль голова живот температура кашель клиника врач доктор таблетка лекарство
спасибо пожалуйста да нет дом машина работа магазин вода еда я ты он она мы вы они где когда как что кто
можно надо хочу могу можете скажите подскажите извините сегодня завтра вчера сейчас помощь проблема вопрос
ответ прием запись страховка карта номер телефон адрес кабинет регистратура анализ кровь давление горло нос ухо
глаз зуб спина грудь сердце рука нога шея кожа дышать дыхание трудно лучше хуже
`.trim().split(/\s+/);

    // Порядок букв как на твоём рисунке
    const KEYBOARD_ROWS = [
      ["й", "ц", "у", "к", "е", "н", "г", "ш", "щ", "з", "х", "ъ"],
      ["ф", "ы", "в", "а", "п", "р", "о", "л", "д", "ж", "э"],
      ["я", "ч", "с", "м", "и", "т", "ь", "б", "ю", "ё"]
    ];

    let trie = {};
    let currentInput = "";
    let freeMode = false;
    let lastGrayTapLetter = null;
    let lastGrayTapTime = 0;

    function normalizeWord(word) {
      return String(word)
        .toLowerCase()
        .replace(/ё/g, "е")
        .trim();
    }

    function prepareWords(words) {
      return [...new Set(
        words
          .map(normalizeWord)
          .filter(word => /^[а-я]+$/.test(word))
      )];
    }

    function buildTrie(words) {
      const root = {};

      for (const word of words) {
        let node = root;

        for (const letter of word) {
          if (!node[letter]) node[letter] = {};
          node = node[letter];
        }

        node.isWord = true;
      }

      return root;
    }

    function getCurrentWord() {
      const parts = currentInput.split(" ");
      return normalizeWord(parts[parts.length - 1] || "");
    }

    function getNode(word) {
      let node = trie;

      for (const letter of word) {
        if (!node[letter]) return null;
        node = node[letter];
      }

      return node;
    }

    function getAvailableLetters() {
      if (freeMode) {
        return new Set(KEYBOARD_ROWS.flat().map(normalizeWord));
      }

      const currentWord = getCurrentWord();
      const node = getNode(currentWord);

      if (!node) return new Set();

      const letters = Object.keys(node)
        .filter(key => key !== "isWord")
        .map(letter => letter === "е" ? "е" : letter);

      return new Set(letters);
    }

    function render() {
      const textBox = document.getElementById("textBox");
      textBox.textContent = currentInput || "—";

      const availableLetters = getAvailableLetters();
      const keyboard = document.getElementById("keyboard");
      keyboard.innerHTML = "";

      KEYBOARD_ROWS.forEach((rowLetters, rowIndex) => {
        const row = document.createElement("div");
        row.className = `row row${rowIndex + 1}`;

        rowLetters.forEach(letter => {
          const normalizedLetter = normalizeWord(letter);
          const button = document.createElement("button");
          button.className = availableLetters.has(normalizedLetter) ? "key" : "key disabled";
          button.textContent = letter.toUpperCase();

          if (availableLetters.has(normalizedLetter)) {
            button.onclick = () => printLetter(letter);
          } else {
            button.onclick = () => handleGrayLetterTap(letter);
          }

          row.appendChild(button);
        });

        keyboard.appendChild(row);
      });

      requestAnimationFrame(() => {
        textBox.scrollTop = textBox.scrollHeight;
      });
    }

    function printLetter(letter) {
      currentInput += letter;
      render();
    }

    function handleGrayLetterTap(letter) {
      const now = Date.now();
      const isDoubleTap = lastGrayTapLetter === letter && now - lastGrayTapTime < 450;

      if (isDoubleTap) {
        freeMode = true;
        printLetter(letter);
        lastGrayTapLetter = null;
        lastGrayTapTime = 0;
        return;
      }

      lastGrayTapLetter = letter;
      lastGrayTapTime = now;
    }

    function removeLastLetter() {
      currentInput = currentInput.slice(0, -1);
      render();
    }

    function clearInput() {
      currentInput = "";
      freeMode = false;
      lastGrayTapLetter = null;
      lastGrayTapTime = 0;
      render();
    }

    function addSpace() {
      if (currentInput && !currentInput.endsWith(" ")) {
        currentInput += " ";
      }

      freeMode = false;
      lastGrayTapLetter = null;
      lastGrayTapTime = 0;
      render();
    }

    async function loadWords() {
      try {
        const response = await fetch(DICTIONARY_URL);
        if (!response.ok) throw new Error("dictionary error");

        const text = await response.text();
        const words = prepareWords(text.split(/\r?\n|\s+/));
        if (words.length < 1000) throw new Error("small dictionary");

        trie = buildTrie(words);
        render();
      } catch (error) {
        trie = buildTrie(prepareWords(FALLBACK_WORDS));
        render();
      }
    }

    loadWords();
  </script>
</body>
</html>
